# =============================================================================
# CLAIMFLOW CONFIGURATION
# Copy to .env and fill in values for your deployment
# =============================================================================

# --- Server ---
NODE_ENV=production                      # development | production | test
PORT=8080                                # API server port

# --- Database (REQUIRED) ---
DATABASE_URL=postgres://claimflow:change_me@postgres:5432/claimflow
DB_POOL_MIN=5                            # Minimum connection pool size
DB_POOL_MAX=20                           # Maximum connection pool size

# --- Storage ---
STORAGE_PATH=/data                       # Root path for document storage

# --- ML Service ---
ML_SERVICE_URL=http://ml:8000            # ML service base URL
ML_TIMEOUT_MS=60000                      # ML request timeout (60s)

# --- Rule Engine ---
RULEPACK_DIR=/data/rulepacks             # Directory containing rulepack versions

# --- Authentication ---
KEY_PATH=/etc/claimflow/keys             # Path to encryption keys directory
JWT_ACCESS_EXPIRY=15m                    # Access token lifetime
JWT_REFRESH_EXPIRY=7d                    # Refresh token lifetime
REQUIRE_MFA=true                         # Enforce MFA for all users
PASSWORD_MIN_LENGTH=12                   # Minimum password length
MAX_LOGIN_ATTEMPTS=5                     # Failed attempts before lockout
LOCKOUT_DURATION_MINUTES=15              # Account lockout duration
SESSION_IDLE_TIMEOUT_MINUTES=30          # Idle session timeout

# --- Security ---
RATE_LIMIT_RPM=100                       # Requests per minute per user
MAX_UPLOAD_SIZE_MB=50                    # Max document upload size (MB)
MAX_PAGES_PER_DOCUMENT=50                # Max pages per uploaded document
MAX_CLAIMS_PER_BATCH=200                 # Max claims in batch audit
BATCH_CONCURRENCY=4                      # Parallel audits in batch

# --- OCR Confidence Thresholds ---
CONF_THRESHOLD_HIGH=0.85                 # Above this = auto-accepted
CONF_THRESHOLD_LOW=0.60                  # Below this = must review
MANUAL_ENTRY_THRESHOLD=0.40              # % of LOW fields to flag manual entry

# --- Licensing ---
LICENSE_TOKEN=                           # Signed JWT from control plane (optional)

# --- Sync / Control Plane ---
CONTROL_PLANE_URL=                       # Control plane URL (optional, empty = no sync)
SYNC_GOVERNANCE_MODE=METRICS_ONLY        # METRICS_ONLY | DEIDENTIFIED | FULL_ANALYTICS
SYNC_INTERVAL_HOURS=6                    # Hours between sync heartbeats

# --- External Integrations ---
AFYALINK_ENV=UAT                         # UAT | PRODUCTION
AFYALINK_CLIENT_ID=                      # AfyaLink API client ID (optional)
AFYALINK_CLIENT_SECRET=                  # AfyaLink API client secret (optional)
CIRCUIT_BREAKER_THRESHOLD=5              # Failures before circuit opens
CIRCUIT_BREAKER_RESET_MS=300000          # 5 minutes before half-open
REGISTRY_CACHE_TTL_HOURS=24              # Cache TTL for registry lookups

# --- Observability ---
LOG_LEVEL=info                           # error | warn | info | debug
