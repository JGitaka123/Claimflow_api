DB_PASSWORD=dev
# Password for the non-superuser claimflow_app role used by the API at runtime
# (Postgres RLS backstop, item 6c). The migration owner connects via DB_PASSWORD;
# the app connects via APP_DB_PASSWORD as claimflow_app. Set a strong value in prod.
APP_DB_PASSWORD=dev
API_PORT=8080
WEB_PORT=3000
ML_PORT=8000
LICENSE_TOKEN=
CONTROL_PLANE_URL=
SYNC_MODE=METRICS_ONLY
CONF_HIGH=0.85
CONF_LOW=0.60
# Per-tenant / per-API-key request budget per minute (item 6d).
TENANT_RATE_LIMIT_RPM=600
API_KEY_RATE_LIMIT_RPM=300
# Bearer token gating GET /metrics (cross-tenant aggregate counts). Leave empty
# to keep /metrics open in dev; set a strong token in production.
METRICS_AUTH_TOKEN=
