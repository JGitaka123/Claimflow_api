# syntax=docker/dockerfile:1.7

FROM node:20-alpine AS build
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages ./packages
RUN find packages -name "*.tsbuildinfo" -delete
RUN find packages/shared/src -type f \( -name "*.js" -o -name "*.d.ts" -o -name "*.js.map" -o -name "*.d.ts.map" \) -delete
RUN pnpm install --frozen-lockfile --prod=false
RUN pnpm --filter @claimflow/api build

FROM node:20-alpine AS runtime
RUN apk add --no-cache curl
RUN addgroup -S claimflow && adduser -S claimflow -G claimflow
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json
COPY --from=build /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=build /app/tsconfig.base.json ./tsconfig.base.json
COPY --from=build /app/packages/shared ./packages/shared
COPY --from=build /app/packages/rule-engine ./packages/rule-engine
COPY --from=build /app/packages/api ./packages/api
USER claimflow
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD curl -fsS http://localhost:8080/health || exit 1
CMD ["node", "--import", "./packages/api/node_modules/tsx/dist/loader.mjs", "packages/api/dist/server.js"]